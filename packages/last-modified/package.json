{
  "name": "markdown-magic-last-modified",
  "version": "2.0.0",
  "description": "Print the last modified date using git for a given file",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "test": "vitest run",
    "docs": "node example.js && prettier --write README.md",
    "prepublishOnly": "npm test && npm run docs && prettier --check .",
    "format": "prettier --write ."
  },
  "prettier": {
    "singleQuote": true
  },
  "license": "MIT",
  "repository": "https://github.com/camacho/markdown-magic-last-modified",
  "author": "Patrick Camacho <patrick@daftdevelopers.com>",
  "keywords": [
    "markdown-magic",
    "last modified",
    "plugin"
  ],
  "peerDependencies": {
    "markdown-magic": "^4"
  },
  "devDependencies": {
    "markdown-magic": "^4.0.0",
    "prettier": "^3.0.0",
    "vitest": "^4.0.0"
  }
}
