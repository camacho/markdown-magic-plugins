{
  "name": "markdown-magic-package-scripts",
  "version": "2.0.0",
  "description": "Print list of scripts in package.json with descriptions",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "test": "vitest run",
    "docs": "node example.js && prettier --write README.md",
    "empty": "echo \"this is just an example\"",
    "format": "prettier --write ."
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/camacho/markdown-magic-plugins.git",
    "directory": "packages/package-scripts"
  },
  "author": "Patrick Camacho <patrick@daftdevelopers.com>",
  "keywords": [
    "markdown",
    "package",
    "scripts",
    "package-scripts",
    "markdown-magic",
    "npm"
  ],
  "dependencies": {
    "find-up": "^8.0.0",
    "sort-scripts": "^1.0.1"
  },
  "peerDependencies": {
    "markdown-magic": "^4"
  },
  "devDependencies": {
    "markdown-magic": "catalog:",
    "prettier": "catalog:",
    "vitest": "catalog:"
  },
  "homepage": "https://github.com/camacho/markdown-magic-plugins#readme",
  "bugs": {
    "url": "https://github.com/camacho/markdown-magic-plugins/issues"
  },
  "files": [
    "index.js"
  ]
}
