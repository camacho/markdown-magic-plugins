{
  "name": "markdown-magic-version-badge",
  "version": "2.1.0",
  "description": "Version badge via Markdown Magic",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc --project tsconfig.build.json",
    "prepack": "pnpm build",
    "test": "vitest run",
    "docs": "node example.ts && prettier --write README.md",
    "format": "prettier --write ."
  },
  "keywords": [
    "markdown-magic",
    "version Badge",
    "plugin"
  ],
  "author": "Patrick Camacho <patrick@daftdevelopers.com>",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/semver": "^7.7.1",
    "markdown-magic": "catalog:",
    "prettier": "catalog:",
    "typescript": "^6.0.3",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "markdown-magic": "^4"
  },
  "dependencies": {
    "find-up": "^8.0.0",
    "semver": "^7.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/camacho/markdown-magic-plugins.git",
    "directory": "packages/version-badge"
  },
  "homepage": "https://github.com/camacho/markdown-magic-plugins#readme",
  "bugs": {
    "url": "https://github.com/camacho/markdown-magic-plugins/issues"
  },
  "files": [
    "dist"
  ]
}
