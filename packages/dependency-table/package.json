{
  "name": "markdown-magic-dependency-table",
  "version": "3.1.0",
  "description": "Generate table of information about dependencies automatically in markdown",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/camacho/markdown-magic-plugins.git",
    "directory": "packages/dependency-table"
  },
  "bugs": {
    "url": "https://github.com/camacho/markdown-magic-plugins/issues"
  },
  "homepage": "https://github.com/camacho/markdown-magic-plugins#readme",
  "author": "Patrick Camacho <patrick@daftdevelopers.com>",
  "keywords": [
    "markdown",
    "dependency table",
    "markdown magic"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc --project tsconfig.build.json",
    "prepack": "pnpm build",
    "test": "vitest run",
    "docs": "node example.ts && prettier --write README.md",
    "format": "prettier --write ."
  },
  "dependencies": {
    "find-up": "^8.0.0",
    "semver": "^7.0.0"
  },
  "peerDependencies": {
    "markdown-magic": "^4"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/semver": "^7.7.1",
    "markdown-magic": "^4.0.0",
    "prettier": "^3.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.0"
  },
  "files": [
    "dist"
  ]
}
