{
  "name": "markdown-magic-dependency-table",
  "version": "3.0.0",
  "description": "Generate table of information about dependencies automatically in markdown",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/camacho/markdown-magic-dependency-table.git"
  },
  "bugs": {
    "url": "https://github.com/camacho/markdown-magic-dependency-table/issues"
  },
  "homepage": "https://github.com/camacho/markdown-magic-dependency-table#readme",
  "author": "Patrick Camacho <patrick@daftdevelopers.com>",
  "keywords": [
    "markdown",
    "dependency table",
    "markdown magic"
  ],
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "test": "vitest run",
    "docs": "node example.js && prettier --write README.md",
    "prepublishOnly": "npm test && npm run docs && prettier --check .",
    "format": "prettier --write ."
  },
  "prettier": {
    "singleQuote": true
  },
  "dependencies": {
    "find-up": "^8.0.0",
    "semver": "^7.0.0"
  },
  "peerDependencies": {
    "markdown-magic": "^4"
  },
  "devDependencies": {
    "markdown-magic": "^4.0.0",
    "prettier": "^3.0.0",
    "vitest": "^4.0.0"
  }
}
