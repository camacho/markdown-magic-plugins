{
  "name": "markdown-magic-directory-tree",
  "version": "2.0.0",
  "description": "Print an archy tree for markdown file",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/camacho/markdown-magic-directory-tree.git"
  },
  "bugs": {
    "url": "https://github.com/camacho/markdown-magic-directory-tree/issues"
  },
  "homepage": "https://github.com/camacho/markdown-magic-directory-tree#readme",
  "author": "Patrick Camacho <patrick@daftdevelopers.com>",
  "keywords": [
    "markdown-magic",
    "archy",
    "tree",
    "directory",
    "directories",
    "directory-tree",
    "markdown",
    "plugin"
  ],
  "scripts": {
    "test": "vitest run",
    "docs": "node example.js && prettier --write README.md",
    "prepublishOnly": "npm test && npm run docs && prettier --check .",
    "format": "prettier --write ."
  },
  "prettier": {
    "singleQuote": true
  },
  "dependencies": {
    "archy": "^1.0.0",
    "directory-tree": "^3.0.0"
  },
  "peerDependencies": {
    "markdown-magic": "^4"
  },
  "devDependencies": {
    "markdown-magic": "^4.0.0",
    "prettier": "^3.0.0",
    "vitest": "^4.0.0"
  }
}
