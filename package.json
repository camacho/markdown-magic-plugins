{
  "name": "markdown-magic-plugins",
  "private": true,
  "description": "markdown-magic transform plugins monorepo",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "test": "turbo run test",
    "docs": "turbo run docs && node example.js && prettier --write README.md",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "markdown-magic": "catalog:",
    "markdown-magic-subpackage-list": "workspace:*",
    "prettier": "catalog:",
    "turbo": "^2.0.0",
    "lefthook": "^2.1.9"
  },
  "pnpm": {
    "overrides": {
      "dotty": "^0.1.2",
      "minimist": "^1.2.8"
    },
    "ignoredBuiltDependencies": [
      "es5-ext",
      "lefthook"
    ]
  }
}
